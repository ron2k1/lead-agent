# Codex review artifacts contain captured commands with absolute user paths.
# The cycles produced this design (DESIGN.md section 15 has the changelog),
# but the raw transcripts leak local filesystem details. Keep them out.
codex-reviews/
.codex-review-prompt.txt

# Per-commit workflow files used to bypass PowerShell quoting on Windows
# (`git commit -F .commitmsg`, `git tag -F .tagmsg-<v>`). These are scratch
# files rewritten before each commit / tag and have no place in the repo.
.commitmsg
.tagmsg-*

# The notify.sh hash is a per-user pin computed by install.ps1 -RepinNotify
# from each cloner's local ~/.claude/tools/notify.sh. Shipping the author's
# hash would silently fail-closed every cloner's hook.
lib/notify-sh.sha256

# Author's working docs that are not part of the public deliverable.
docs/readme-review.md
docs/security-audit.md
docs/launch-posts.md

# Build / runtime / OS / editor cruft.
*.log
*.bak
*.tmp
*.swp
__pycache__/
*.pyc
*.pyo
*.pyd
.DS_Store
Thumbs.db
.idea/
.vscode/
